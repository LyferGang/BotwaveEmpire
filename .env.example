# Botwave Empire Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# LLM Configuration (LM Studio)
# =============================================================================
LLM_API_URL=http://host.docker.internal:1234/v1
LLM_API_KEY=not-needed-for-local
LLM_MODEL=qwen3.5-4b-uncensored-hauhaucs-aggressive
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=sqlite:///data/botwave.db

# =============================================================================
# API Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change-this-in-production
API_DEBUG=false

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_LOG_LEVEL=INFO

# =============================================================================
# Cloudflare (for website deployment)
# =============================================================================
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-zone-id
CF_ACCOUNT_ID=your-account-id

# =============================================================================
# GitHub (for MCP server)
# =============================================================================
GITHUB_TOKEN=your-github-personal-access-token

# =============================================================================
# Optional: Telegram Notifications
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Paths (used in Docker containers)
# =============================================================================
DATA_DIR=/app/data
LOGS_DIR=/app/logs
VAULT_DIR=/app/vault
