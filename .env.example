# Botwave Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit real credentials to version control

# =============================================================================
# LLM Configuration (LM Studio - Local)
# =============================================================================
LLM_API_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=your-model-name
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# =============================================================================
# Telegram Bot Tokens
# =============================================================================
TG_FOREMAN_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# Stripe Integration (Business Platform Payments)
# =============================================================================
# Get your keys from https://dashboard.stripe.com/apikeys
# IMPORTANT: Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs for subscription plans (create in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_ID_PROFESSIONAL=price_YOUR_PROFESSIONAL_PRICE_ID

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=generate-a-secure-random-string-here
API_DEBUG=false

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_LOG_LEVEL=INFO

# =============================================================================
# Paths
# =============================================================================
DATA_DIR=./data
LOGS_DIR=./logs
VAULT_DIR=./vault
