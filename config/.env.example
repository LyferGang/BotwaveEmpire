# Botwave Empire Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================
LLM_API_URL=http://localhost:1234/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=qwen2.5-7b-instruct
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=sqlite:///data/botwave.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/botwave

# =============================================================================
# API Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=generate-a-secure-secret-key
API_DEBUG=false

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_LOG_LEVEL=INFO

# =============================================================================
# Optional Integrations
# =============================================================================
# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Webhook URL for job completion (optional)
# WEBHOOK_URL=https://your-server.com/webhook

# =============================================================================
# Paths
# =============================================================================
DATA_DIR=/app/data
LOGS_DIR=/app/logs
VAULT_DIR=/app/vault
