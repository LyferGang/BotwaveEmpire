# Botwave Environment Configuration
# Copy from .env.example for your local settings

# =============================================================================
# LLM Configuration (LM Studio - Local)
# Model: qwen3.5-4b-uncensored-hauhaucs-aggressive
# Context: 32768 | Parallel: 4 | Fast Response Optimized
# =============================================================================
LLM_API_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen3.5-4b-uncensored-hauhaucs-aggressive
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_CONTEXT_WINDOW=8192
LLM_REQUEST_TIMEOUT=15

# =============================================================================
# Telegram Bot Tokens
# =============================================================================
# Bot for dad's plumbing business customer inquiries
TG_PLUMBING_BOT_TOKEN=8747407183:AAHimCXAm0SleFh7DCW_xxmH7vn09nnAZ3k
# Your personal chat ID for notifications
TELEGRAM_CHAT_ID=8711428786
# Foreman bot (for internal use)
TG_FOREMAN_TOKEN=8747407183:AAHimCXAm0SleFh7DCW_xxmH7vn09nnAZ3k

# =============================================================================
# Stripe Integration (Business Platform Payments)
# =============================================================================
# IMPORTANT: Set these in production environment or use a secure secrets manager
# GitHub blocks commits with live Stripe keys - use environment variables in production
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# =============================================================================
# GitHub Personal Access Token
# =============================================================================
GH_PAT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Cloudflare API Key
# =============================================================================
CF_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change-this-in-production
API_DEBUG=false

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_LOG_LEVEL=INFO

# =============================================================================
# Paths
# =============================================================================
DATA_DIR=/home/gringo/BotwaveEmpire/data
LOGS_DIR=/home/gringo/BotwaveEmpire/logs
VAULT_DIR=/home/gringo/BotwaveEmpire/vault
