#!/usr/bin/env python3
"""
BOTWAVE TUI - Simple Chat Interface
Uses your local LM Studio (no cloud APIs needed)
"""

import os
import sys

# Get config from environment (same as your container)
API_URL = os.getenv("OPENAI_BASE_URL", "http://localhost:1234/v1")
MODEL = os.getenv("OPENAI_API_MODEL", "qwen3.5-4b-uncensored-hauhaucs-aggressive")

def chat(prompt, history=None):
    """Send message to LM Studio and get response."""
    import requests
    import json

    messages = [
        {"role": "system", "content": "You are BOTWAVE, a helpful AI coding assistant. Be concise and helpful."}
    ]

    if history:
        messages.extend(history)

    messages.append({"role": "user", "content": prompt})

    try:
        resp = requests.post(
            f"{API_URL}/chat/completions",
            json={
                "model": MODEL,
                "messages": messages,
                "stream": False,
                "temperature": 0.7,
            },
            timeout=60
        )

        if resp.status_code == 200:
            data = resp.json()
            return data["choices"][0]["message"]["content"]
        else:
            return f"Error: {resp.status_code} - {resp.text}"

    except requests.exceptions.ConnectionError:
        return "Cannot connect to LM Studio. Make sure it's running on port 1234."
    except Exception as e:
        return f"Error: {e}"


def main():
    print("=" * 50)
    print("BOTWAVE TUI - Local AI Chat")
    print(f"Model: {MODEL}")
    print(f"API: {API_URL}")
    print("=" * 50)
    print("Type 'quit' to exit, 'clear' to reset history\n")

    history = []

    while True:
        try:
            user_input = input("You> ").strip()

            if not user_input:
                continue

            if user_input.lower() in ("quit", "exit", "q"):
                print("Goodbye!")
                break

            if user_input.lower() == "clear":
                history = []
                print("History cleared.\n")
                continue

            print("\nBOTWAVE> ", end="", flush=True)
            response = chat(user_input, history)
            print(response)
            print()

            # Add to history
            history.append({"role": "user", "content": user_input})
            history.append({"role": "assistant", "content": response})

            # Keep history manageable
            if len(history) > 20:
                history = history[-20:]

        except KeyboardInterrupt:
            print("\nInterrupted. Type 'quit' to exit.")
        except EOFError:
            break


if __name__ == "__main__":
    main()
