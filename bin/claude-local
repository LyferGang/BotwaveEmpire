#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# CLAUDE LOCAL - Run Claude Code with LM Studio (100% FREE)
# Uses LM Studio's Anthropic-compatible endpoint
# No API costs - runs on your local GPU
# ═══════════════════════════════════════════════════════════════

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║${NC}  ${GREEN}CLAUDE LOCAL - LM Studio Powered${NC}  ${CYAN}║${NC}"
echo -e "${CYAN}║${NC}  100% FREE - No API Costs${NC}              ${CYAN}║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

# Check LM Studio
echo -n "Checking LM Studio... "
if curl -s http://localhost:1234/v1/models | grep -q '"data"'; then
    echo -e "${GREEN}RUNNING${NC}"
    MODEL=$(curl -s http://localhost:1234/v1/models | python3 -c "import sys,json; d=json.load(sys.stdin); m=d.get('data',[{}])[0].get('id','unknown'); print(m)" 2>/dev/null || echo "unknown")
    echo "  Model: $MODEL"
else
    echo -e "${RED}NOT RUNNING${NC}"
    echo ""
    echo "Start LM Studio server first:"
    echo "  lms server start"
    echo ""
    exit 1
fi

# Export environment variables for Anthropic compatibility
export ANTHROPIC_BASE_URL=http://localhost:1234/v1
export ANTHROPIC_AUTH_TOKEN=lmstudio

# Find Claude CLI
CLAUDE_BIN=$(which claude 2>/dev/null || echo "")

if [ -z "$CLAUDE_BIN" ]; then
    echo -e "${RED}Claude CLI not found${NC}"
    echo "Install with: npm install -g @anthropic-ai/claude-code"
    exit 1
fi

echo ""
echo -e "${GREEN}Starting Claude with LM Studio backend...${NC}"
echo "  Endpoint: $ANTHROPIC_BASE_URL"
echo ""

# Launch Claude with local backend
exec "$CLAUDE_BIN" "$@"
